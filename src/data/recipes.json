[
  {
    "id": "tomato-egg",
    "name": "西红柿炒鸡蛋",
    "category": "家常菜",
    "difficulty": 1,
    "time": 15,
    "servings": 2,
    "status": "todo",
    "tags": ["快手", "下饭", "新手友好"],
    "ingredients": [
      { "name": "西红柿", "amount": "2个" },
      { "name": "鸡蛋", "amount": "3个" },
      { "name": "葱", "amount": "1根" },
      { "name": "盐", "amount": "适量" },
      { "name": "糖", "amount": "1小勺" },
      { "name": "食用油", "amount": "2汤匙" }
    ],
    "steps": [
      "鸡蛋打散加少许盐，西红柿切块，葱切末。",
      "热锅倒油，油热后倒入蛋液，炒到刚凝固就盛出备用。",
      "锅里留底油，下西红柿翻炒出汁，加1小勺糖提味。",
      "倒入炒好的鸡蛋，翻炒均匀，加盐调味，撒葱花出锅。"
    ],
    "notes": "新手第一道菜首选。鸡蛋不要炒太老，西红柿要炒出汁水才好吃。"
  },
  {
    "id": "garlic-broccoli",
    "name": "蒜蓉西兰花",
    "category": "家常菜",
    "difficulty": 1,
    "time": 12,
    "servings": 2,
    "status": "todo",
    "tags": ["健康", "快手", "新手友好"],
    "ingredients": [
      { "name": "西兰花", "amount": "1颗" },
      { "name": "大蒜", "amount": "4瓣" },
      { "name": "盐", "amount": "适量" },
      { "name": "蚝油", "amount": "1汤匙" },
      { "name": "食用油", "amount": "2汤匙" }
    ],
    "steps": [
      "西兰花掰小朵，用盐水泡10分钟后冲洗干净。",
      "烧一锅水加点盐和油，西兰花焯水1-2分钟捞出过凉水。",
      "热锅下油爆香蒜末，倒入西兰花快速翻炒。",
      "加蚝油和盐调味，翻炒均匀即可出锅。"
    ],
    "notes": "焯水后过凉水能保持翠绿和脆嫩。"
  },
  {
    "id": "soy-chicken-wings",
    "name": "可乐鸡翅",
    "category": "家常菜",
    "difficulty": 2,
    "time": 35,
    "servings": 3,
    "status": "todo",
    "tags": ["下饭", "宴客"],
    "ingredients": [
      { "name": "鸡翅中", "amount": "10个" },
      { "name": "可乐", "amount": "1罐" },
      { "name": "生抽", "amount": "2汤匙" },
      { "name": "姜", "amount": "3片" },
      { "name": "料酒", "amount": "1汤匙" }
    ],
    "steps": [
      "鸡翅两面划几刀，冷水下锅加料酒姜片焯水去腥，捞出洗净。",
      "热锅少油，把鸡翅煎到两面金黄。",
      "倒入可乐没过鸡翅，加生抽和姜片，大火烧开转中小火。",
      "炖15-20分钟，最后大火收汁到浓稠裹满鸡翅即可。"
    ],
    "notes": "可乐本身有糖，不用再加糖。收汁要看着点别糊锅。"
  }
]
