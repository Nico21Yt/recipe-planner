# 复制这份为 .env 在本地用 `vercel dev` 调试；线上请在 Vercel 项目设置里配置同名变量。
# 注意：.env 已被 .gitignore 忽略，绝不会提交到 GitHub。

# 必填：OpenAI API Key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# 可选：模型名（默认 gpt-5.4）
OPENAI_MODEL=gpt-5.4

# 可选：接口地址（默认官方 https://api.openai.com/v1，走代理时改这里）
OPENAI_BASE_URL=https://api.openai.com/v1

# --- 云端共享数据：Upstash Redis（在 Vercel 后台创建 Redis 集成后自动注入）---
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxx

# --- 云端照片：Vercel Blob（在 Vercel 后台创建 Blob 存储后自动注入）---
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# 可选（仅当前端和后端分开部署时）：前端调用的后端地址
# VITE_AI_API=https://你的后端域名/api/generate-recipe
# VITE_DATA_API=https://你的后端域名/api/data
# VITE_UPLOAD_API=https://你的后端域名/api/upload
